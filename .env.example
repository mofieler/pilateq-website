# Pilateq Production Environment Variables
# Copy this file to .env for local testing or set the values in Coolify.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Resend API key (get it from https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender address in Resend (must match a domain you verified)
RESEND_FROM_EMAIL=Pilateq <info@pilateq.de>

# Your public domain (used for logo URLs and CORS)
PUBLIC_SITE_URL=https://pilateq.de

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Email address that receives contact form submissions
ADMIN_EMAIL=info@pilateq.de

# Port the Node server listens on (Coolify usually sets this automatically)
PORT=3001

# Node environment
NODE_ENV=production

# Rate limiting: window in ms (default 15 min) and max requests per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5

# If frontend and backend run on separate origins, set the frontend URL here.
# In the single-service Coolify setup this defaults to PUBLIC_SITE_URL.
# FRONTEND_URL=https://pilateq.de
